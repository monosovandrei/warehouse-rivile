RIVILE_API_KEY=replace_with_rivile_api_key
RIVILE_API_URL=https://api.manorivile.lt/client/v2
RIVILE_PAGE_LIMIT=1000
RIVILE_REQUEST_DELAY_MS=150

TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
# Optional. Get it from /chatid after adding the bot to a group.
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

REPORT_TIME_ZONE=Europe/Moscow
REPORT_CURRENCY=EUR

# Optional overrides. By default the current Servermall mapping is already built in.
# REPORT_DEPARTMENT_MAP_JSON={"103":"CS","104":"Отдел Продаж","105":"Отдел Продаж","107":"CS","115":"Отдел Продаж","118":"CS","120":"CS","121":"Отдел Продаж","122":"CS","124":"Отдел Продаж","125":"Отдел Продаж","126":"CS","127":"Отдел Продаж"}
# REPORT_MANAGER_NAME_MAP_JSON={"103":"Серафима","104":"Сергей","105":"Билал","107":"Стефанчик","115":"Эд","118":"Кристина","120":"Антонио","121":"Андрей","122":"Ася","124":"Вита","125":"Артемий","126":"Илья","127":"Саша"}
