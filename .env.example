# Local Telegram MTD revenue/margin bot. Create a bot via @BotFather, add it to the group, then run npm run bot locally.
# Use /chatid in the group to get the ID and set TELEGRAM_ALLOWED_CHAT_IDS if you want to limit access.
# TELEGRAM_BOT_TOKEN=123456789:replace_with_bot_token
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
REPORT_TIME_ZONE=Europe/Moscow
REPORT_CURRENCY=EUR
# Optional: manager code/name to department and short display names.
# REPORT_DEPARTMENT_MAP_JSON={"103":"CS","104":"Отдел Продаж","105":"Отдел Продаж","107":"CS","115":"Отдел Продаж","118":"CS","120":"CS","121":"Отдел Продаж","122":"CS","124":"Отдел Продаж","125":"Отдел Продаж","126":"CS","127":"Отдел Продаж"}
# REPORT_MANAGER_NAME_MAP_JSON={"103":"Серафима","104":"Сергей","105":"Билал","107":"Стефанчик","115":"Эд","118":"Кристина","120":"Антонио","121":"Андрей","122":"Ася","124":"Вита","125":"Артемий","126":"Илья","127":"Саша"}

# Foreign supplier stock feed. Production should point to supplier snapshot API on another server.
FOREIGN_STOCK_SNAPSHOT_TTL_MS=86400000
FOREIGN_STOCK_SYNC_HOUR=3
FOREIGN_STOCK_STALE_DAYS=5
FOREIGN_STOCK_DELIVERY_BUSINESS_DAYS=10
FOREIGN_STOCK_CURRENCY=EUR
# Set one source. JSON/CSV API is preferred for production; exported Telegram HTML is accepted only for testing.
# FOREIGN_STOCK_SOURCE_URL=https://supplier.example.local/api/warehouse-snapshot
# FOREIGN_STOCK_SOURCE_PATH=C:\warehouse\imports\supplier-price.csv
# Optional API auth / networking:
FOREIGN_STOCK_SOURCE_TIMEOUT_MS=30000
# FOREIGN_STOCK_SOURCE_TOKEN=replace_with_supplier_api_token
# FOREIGN_STOCK_SOURCE_AUTH_HEADER=Authorization
# FOREIGN_STOCK_SOURCE_HEADERS_JSON={"X-API-Key":"replace_with_supplier_api_key"}
# Optional if column auto-detection is not enough:
# FOREIGN_STOCK_CATEGORY_COLUMN=Category
# FOREIGN_STOCK_CODE_COLUMN=Code
# FOREIGN_STOCK_NAME_COLUMN=Name
# FOREIGN_STOCK_BRAND_COLUMN=Brand
# FOREIGN_STOCK_SUPPLIER_COLUMN=Supplier
# FOREIGN_STOCK_QTY_COLUMN=Qty
# FOREIGN_STOCK_PRICE_COLUMN=Price
# FOREIGN_STOCK_CURRENCY_COLUMN=Currency
# FOREIGN_STOCK_PRICE_TYPE_COLUMN=PriceType
# FOREIGN_STOCK_DATE_COLUMN=Date
